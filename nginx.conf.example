# RuEduCMS — nginx с базовой защитой от перегрузки
# Для своего VPS — укажите root и fastcgi_pass:

limit_req_zone $binary_remote_addr zone=ruedu_general:10m rate=10r/s;
limit_conn_zone $binary_remote_addr zone=ruedu_conn:10m;

server {
    listen 80;
    server_name example.com;
    root /var/www/rueducms;
    index index.php;

    client_max_body_size 10m;
    client_body_timeout 12s;
    client_header_timeout 12s;
    send_timeout 12s;

    location / {
        limit_req zone=ruedu_general burst=20 nodelay;
        limit_conn ruedu_conn 20;
        try_files $uri $uri/ /index.php?$is_args$args;
    }

    # Публичные ресурсы ядра (логотип по умолчанию и т.п.)
    location ^~ /core/assets/ {
        try_files $uri =404;
    }

    # SCSS тем: themes/{slug}/style.css — виртуальный URL, обрабатывается index.php

    # Служебные папки — только через PHP include, не по HTTP
    location ~ ^/(core(?!/assets)|storage|config|content/modules)(/|$) {
        deny all;
        return 403;
    }

    location = /config.php {
        deny all;
        return 403;
    }

    location ~ \.php$ {
        limit_req zone=ruedu_general burst=10 nodelay;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_read_timeout 30s;
    }
}
