RewriteEngine On
Options -Indexes

# Кастомные страницы ошибок (403 — через error.php?code=403 в RewriteRule)
ErrorDocument 400 error.php
ErrorDocument 401 error.php
ErrorDocument 404 error.php
ErrorDocument 500 error.php
ErrorDocument 503 error.php

# Алиасы для пользовательского контента (чистые URL без content/)
RewriteRule ^themes/(.*)$ content/themes/$1 [L]
RewriteRule ^uploads/(.*)$ content/uploads/$1 [L]
RewriteRule ^admin/assets/(.*)$ admin/assets/$1 [L]

# Защита ядра и служебных папок
RewriteRule ^config(/.*)?$ error.php?code=403 [L,QSA]
RewriteRule ^core(/.*)?$ error.php?code=403 [L,QSA]
RewriteRule ^storage(/.*)?$ error.php?code=403 [L,QSA]
RewriteRule ^content/modules(/.*)?$ error.php?code=403 [L,QSA]

# Запрет прямого доступа к config.php
RewriteRule ^config\.php$ error.php?code=403 [L,QSA]

# Статические файлы (кроме robots.txt — генерируется CMS)
RewriteCond %{REQUEST_URI} !robots\.txt$ [NC]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Установщик
RewriteRule ^install(/.*)?$ install/index.php [L,QSA]

# Админка
RewriteRule ^admin(/.*)?$ admin/index.php [L,QSA]

# Sitemap
RewriteRule ^sitemap\.xml$ index.php?route=sitemap [L,QSA]

# Публичные маршруты
RewriteRule ^(.*)$ index.php [L,QSA]
